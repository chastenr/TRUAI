# Copy this file to .env.local and fill in your keys.

# Without ANTHROPIC_API_KEY the chat returns a demo-mode fallback message.
ANTHROPIC_API_KEY=sk-ant-...

# Required for real HubSpot CRM lead creation/update.
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-...

# Optional: send a lead notification email after HubSpot saves the contact.
RESEND_API_KEY=re_...
LEAD_NOTIFICATION_EMAIL=admin@example.com
LEAD_NOTIFICATION_FROM="NALA Leads <onboarding@resend.dev>"

BASE_URL=http://localhost:3000

# ─── Vapi Integration ─────────────────────────────────────────────────────────
# Shared secret sent by Vapi in the x-vapi-secret header on every tool call.
# Set this in your Vapi dashboard under Assistant > Server URL > Headers.
# Leave blank during local testing if you don't need auth yet.
VAPI_WEBHOOK_SECRET=

# ─── AI Phone Receptionist MVP ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+15555550100
REAL_AGENT_PHONE_NUMBER=+15555550199

# Public wss:// URL for the Node WebSocket bridge, for example:
# wss://your-phone-bridge.example.com/api/twilio/media-stream
TWILIO_MEDIA_STREAM_URL=wss://your-phone-bridge.example.com/api/twilio/media-stream
