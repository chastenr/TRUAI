# Copy this file to .env.local and fill in your keys.

# Without ANTHROPIC_API_KEY the chat returns a demo-mode fallback message.
ANTHROPIC_API_KEY=sk-ant-...

# Required for real HubSpot CRM lead creation/update.
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-...

# Optional: send a lead notification email after HubSpot saves the contact.
RESEND_API_KEY=re_...
LEAD_NOTIFICATION_EMAIL=admin@example.com
LEAD_NOTIFICATION_FROM="NALA Leads <onboarding@resend.dev>"

BASE_URL=http://localhost:3000
