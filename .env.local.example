# Copy this file to .env.local and fill in your keys.
# ─────────────────────────────────────────────────────────────────────────────
# VARIABLE USAGE MAP
# ─────────────────────────────────────────────────────────────────────────────
# VAPI_WEBHOOK_SECRET  → used by /api/vapi/* to validate x-vapi-secret header
# HUBSPOT_PRIVATE_APP_TOKEN → used by /api/leads and /api/vapi/* for CRM sync
# RESEND_API_KEY       → used by /api/leads and /api/vapi/* for email alerts
# LEAD_NOTIFICATION_EMAIL → destination for Resend alerts
#
# NOT currently used by backend code (Vapi handles outbound SMS/voice directly):
# VAPI_API_KEY, VAPI_ASSISTANT_ID, VAPI_PHONE_NUMBER_ID
# TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_PHONE_NUMBER
# ─────────────────────────────────────────────────────────────────────────────

# ─── Vapi Integration ─────────────────────────────────────────────────────────
# REQUIRED — must match the x-vapi-secret header value in your Vapi dashboard.
# Set this in Vercel AND in the Vapi dashboard → Assistant/Phone Number → HTTP Headers:
#   Header: x-vapi-secret
#   Value:  <same value as below>
VAPI_WEBHOOK_SECRET=your-secret-here

# Optional — only needed if backend initiates outbound Vapi API calls (not currently used)
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=

# ─── HubSpot CRM ──────────────────────────────────────────────────────────────
# Required for /api/leads and /api/vapi/lead|property-inquiry|book-showing CRM sync
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-...

# ─── Lead Email Notifications ─────────────────────────────────────────────────
# Optional — send a notification email when a Vapi or website lead is captured
RESEND_API_KEY=re_...
LEAD_NOTIFICATION_EMAIL=admin@example.com
LEAD_NOTIFICATION_FROM="NALA Leads <onboarding@resend.dev>"

# ─── App ──────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:3000

# ─── AI Brain (Anthropic) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Twilio (informational — Vapi owns the webhooks, backend does not send SMS) ─
# Only needed if you add a backend SMS-send feature in the future.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+14702565261

# ─── Legacy phone receptionist (not used by Vapi flow) ───────────────────────
OPENAI_API_KEY=sk-...
REAL_AGENT_PHONE_NUMBER=+15555550199
TWILIO_MEDIA_STREAM_URL=wss://your-phone-bridge.example.com/api/twilio/media-stream

# ─── Trulience Avatar (public — safe to expose) ───────────────────────────────
NEXT_PUBLIC_TRULIENCE_AVATAR_ID=3114376038906087505
NEXT_PUBLIC_TRULIENCE_TOKEN=tru_live_...
